TRAQ_BOT_TOKEN=replace-with-your-bot-token
TRAQ_BOT_ID=00000000-0000-0000-0000-000000000000
TRAQ_USER_TOKEN=replace-with-your-user-token

DB_HOST=localhost
DB_PORT=3306
DB_NAME=bot127
DB_USER=bot127
DB_PASSWORD=replace-with-your-db-password
# または DATABASE_URL=jdbc:mariadb://localhost:3306/bot127

# 転送ルールを登録する設定チャンネル（パス形式）。未設定時は全チャンネルで !forward コマンドを受け付けます。
# FORWARD_CONFIG_CHANNEL=times/bot127

# DB が空のときだけ投入する初期ルール（セミコロン区切り）。
# 形式: チャンネルパス|正規表現|転送先ユーザーUUID
# FORWARD_RULES=general/alerts|/error.*/|00000000-0000-0000-0000-000000000001
